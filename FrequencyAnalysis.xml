<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>APPIL</category>
    <title>FrequencyAnalysis</title>
    <description>
        Frequency analysis of image
    </description>
    <version>0.2</version>
    <documentation-url></documentation-url>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <longflag>inputImageName</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be analyzed</description>
        </image>
        <string>
            <longflag>outputDirectory</longflag>
            <label>Output Directory</label>
            <description>directory for output frequency, mask images</description>
        </string>
        <string>
            <longflag>inputCSVName</longflag>
            <label>path for input MTF csv</label>
        </string>
    </parameters>

    <parameters>
        <label>Coordinates</label>
        <description>RAS coordinates of axial in-plane airway recist diameter and slice</description>
        <float>
            <longflag>aR</longflag>
            <label>Right coordinate of first recist point</label>
            <default>68.4</default>
        </float>
        <float>
            <longflag>aA</longflag>
            <label>Anterior coordinate of first recist point</label>
            <default>142.3</default>
        </float>
        <float>
            <longflag>bR</longflag>
            <label>Right coordinate of second recist point</label>
            <default>65.7</default>
        </float>
        <float>
            <longflag>bA</longflag>
            <label>Anterior coordinate of second recist point</label>
            <default>137.9</default>
        </float>
        <integer>
            <longflag>slice</longflag>
            <label>Axial slice coordinate of airway recist diameter points</label>
            <default>961</default>
        </integer>
    </parameters>

    <parameters>
        <label>ROI Calculation</label>
        <description>Variables for ROI calculation</description>
        <float>
            <longflag>roiMult</longflag>
            <label>RECIST distance multiplier for ROI calculation</label>
            <default>1.0</default>
        </float>
    </parameters>

    <parameters>
        <label>Modulation</label>
        <description>Modulations desired for analysis band</description>
        <float>
            <longflag>modLow</longflag>
            <label>Low modulation</label>
            <default>0.1</default>
        </float>
        <float>
            <longflag>modHigh</longflag>
            <label>High modulation</label>
            <default>0.6</default>
        </float>

    </parameters>


</executable>
